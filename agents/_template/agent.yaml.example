# Agent configuration
# Copy this folder, rename it, and fill in your values.
#
# Then add your bot token to .env:
#   MYAGENT_BOT_TOKEN=1234567890:AAFxxxxxxx
#
# Start with:
#   npm start -- --agent myagent

name: My Agent
description: What this agent does

# The env var name in .env that holds this agent's Telegram bot token.
# Create a bot via @BotFather in Telegram, paste the token into .env.
telegram_bot_token_env: MYAGENT_BOT_TOKEN

# Default model. Options: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
# Users can override per-chat with /model in Telegram.
model: claude-sonnet-4-6

# Restrict access to specific Telegram chat IDs (optional).
# Get your chat ID by sending /chatid to the bot.
# chat_ids:
#   - "123456789"

# System prompt injected into every conversation (optional).
# Falls back to CLAUDE.md in the agent directory if not set.
# system_prompt: >
#   You are a helpful assistant for ...

# Skills this agent has access to (optional).
# List skill directory names from skills/.
# skills:
#   - Lead_generation

# Environment variables passed to skills at runtime (optional).
# Values can be literal or env var names from .env (auto-resolved).
# skill_env:
#   APIFY_API_TOKEN: MY_APIFY_TOKEN
#   GOOGLE_CREDENTIALS_PATH: /path/to/credentials.json
#   GOOGLE_TOKEN_PATH: /path/to/token.json
#   LEADS_DRIVE_FOLDER_ID: abc123

# Obsidian integration (optional).
# Assign folders from your vault so this agent auto-loads relevant context.
# obsidian:
#   vault: /path/to/your/obsidian/vault
#   folders:
#     - FolderA/
#     - FolderB/
#   read_only:
#     - Daily Notes/
